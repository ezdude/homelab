# ---- Copy to .env and fill in. Never commit .env. ----

# Google AI Studio API key (free): https://aistudio.google.com/app/apikey
# NOTE: Use google-genai SDK (not legacy google-generativeai).
# Check available models for your key: GET /v1beta/models?key=YOUR_KEY
# Current working models: gemini-embedding-001 (embeddings), gemini-2.5-flash (chat)
GOOGLE_API_KEY=

# Single password used to log into the app. Choose something strong — this app
# is internet-facing. Generate with: openssl rand -base64 20
APP_PASSWORD=

# Secret used to sign the session cookie. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# The public hostname Caddy (or your reverse proxy) serves this app on.
APP_HOST=brain.YOUR_DOMAIN

# Cookie Secure flag. Leave as 'true' in production (HTTPS).
# Set to 'false' ONLY for local http testing.
COOKIE_SECURE=true

# Where synthesis (.md) documents are stored inside the container.
# The host path is bind-mounted in docker-compose.yml.
# Point the host path at a Nextcloud-synced directory to get Obsidian sync.
# SYNTHESIS_DIR=./data/synthesis
